---
import HomePage from "@components/HomePage.astro";
import { getHomeData } from "@lib/home";
import { useTranslations, getLangFromUrl } from "@i18n/utils";
import { HOME } from "@consts";

const lang = getLangFromUrl(Astro.url.pathname);
const { blog, projects, work } = await getHomeData(lang);
const t = useTranslations(lang);
---

<HomePage
  title={HOME.TITLE}
  description={HOME.DESCRIPTION}
  heroTitle={t("home.hero.title")}
  heroText={t("home.hero.text")}
  postsTitle={t("home.posts.title")}
  postsLink={t("home.posts.seeAll")}
  projectsTitle={t("home.projects.title")}
  projectsLink={t("home.projects.seeAll")}
  workTitle={t("home.work.title")}
  workLink={t("home.work.seeAll")}
  connectTitle={t("home.connect.title")}
  connectText={t("home.connect.text")}
  blog={blog}
  projects={projects}
  work={work}
/>
