---
import { type Lang } from "@i18n/ui";

interface Props {
  date: Date;
  lang: Lang;
}

const { date, lang } = Astro.props;

const localeMap: Record<Lang, string> = {
  ru: "ru-RU",
  en: "en-US",
};
---

<time datetime={date.toISOString()}>
  {
    date.toLocaleDateString(localeMap[lang], {
      month: "short",
      day: "numeric",
      year: "numeric",
    })
  }
</time>
