---
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { dateRange } from "@lib/utils";
import { SITE, SOCIALS, HOME } from "@consts";
import { render } from "astro:content";
import { getLangFromUrl, useTranslations, localizedPath } from "@i18n/utils";
import { getHomeData } from "@lib/home";

const lang = getLangFromUrl(Astro.url.pathname);
const t = useTranslations(lang);
const { blog, projects, work } = await getHomeData(lang);

const title = t("home.title");
const description = HOME.DESCRIPTION;

const renderedWork = await Promise.all(
  work.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  }),
);

const blogHref = localizedPath("/blog", lang);
const projectsHref = localizedPath("/projects", lang);
const workHref = localizedPath("/work", lang);
---

<PageLayout {title} {description}>
  <Container>
    <h4 class="animate font-semibold text-black dark:text-white">
      {t("home.hero.title")}
    </h4>
    <div class="space-y-16">
      <section>
        <article class="space-y-4">
          <p class="animate">{t("home.hero.text")}</p>
        </article>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            {t("home.posts.title")}
          </h5>
          <Link href={blogHref}>{t("home.posts.seeAll")}</Link>
        </div>
        <ul class="flex flex-col gap-4">
          {
            blog.map((post) => (
              <li>
                <ArrowCard entry={post} {lang} />
              </li>
            ))
          }
        </ul>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            {t("home.work.title")}
          </h5>
          <Link href={workHref}>{t("home.work.seeAll")}</Link>
        </div>
        <ul class="flex flex-col space-y-4">
          {
            renderedWork.map(({ entry, Content }) => (
              <li>
                <div class="text-sm opacity-75">
                  {dateRange(
                    entry.data.dateStart,
                    entry.data.dateEnd,
                    lang,
                  )}
                </div>
                <div class="font-semibold text-black dark:text-white">
                  {entry.data.company}
                </div>
                <div class="text-sm opacity-75">{entry.data.role}</div>
                <article>
                  <Content />
                </article>
              </li>
            ))
          }
        </ul>
      </section>

      {
        SITE.PROJECTS_ENABLED && (
          <section class="animate space-y-6">
            <div class="flex flex-wrap gap-y-2 items-center justify-between">
              <h5 class="font-semibold text-black dark:text-white">
                {t("home.projects.title")}
              </h5>
              <Link href={projectsHref}>{t("home.projects.seeAll")}</Link>
            </div>
            <ul class="flex flex-col gap-4">
              {projects.map((project) => (
                <li>
                  <ArrowCard entry={project} {lang} />
                </li>
              ))}
            </ul>
          </section>
        )
      }

      <section class="animate space-y-4">
        <h5 class="font-semibold text-black dark:text-white">
          {t("home.connect.title")}
        </h5>
        <article>
          <p>{t("home.connect.text")}</p>
        </article>
        <ul class="flex flex-wrap gap-2">
          {
            SOCIALS.map((SOCIAL) => (
              <li class="flex gap-x-2 text-nowrap">
                <Link
                  href={SOCIAL.HREF}
                  external
                  aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}
                >
                  {SOCIAL.NAME}
                </Link>
                {"/"}
              </li>
            ))
          }
          <li class="line-clamp-1">
            <Link
              href={`mailto:${SITE.EMAIL}`}
              aria-label={`Email ${SITE.NAME}`}
            >
              {SITE.EMAIL}
            </Link>
          </li>
        </ul>
      </section>
    </div>
  </Container>
</PageLayout>