---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { switchLang, useTranslations, getLangFromUrl } from "@i18n/utils";
import { SITE } from "@consts";

const lang = getLangFromUrl(Astro.url.pathname);
const t = useTranslations(lang);
---

<header>
  <Container>
    <div class="flex flex-wrap gap-y-2 justify-between">
      <Link href="/" underline={false}>
        <div class="font-semibold">
          {SITE.NAME}
        </div>
      </Link>
      <nav class="flex gap-1 items-center">
        <Link href="/blog"> {t("header.blog")} </Link>
        <span>
          {`/`}
        </span>
        <Link href="/work"> {t("header.work")} </Link>
        <span>
          {`/`}
        </span>
        <Link href="/projects"> {t("header.projects")} </Link>
        <span class="text-gray-400">
          {`| `}
        </span>
        <Link href={switchLang(Astro.url.pathname)}>
          {lang === "ru" ? "en" : "ru"}
        </Link>
      </nav>
    </div>
  </Container>
</header>
